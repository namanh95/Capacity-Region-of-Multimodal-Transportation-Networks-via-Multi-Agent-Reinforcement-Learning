import numpy as np
import matplotlib.pyplot as plt
from matplotlib import cm

# --------------------------------------------------
# Publication-style plotting parameters
# --------------------------------------------------
plt.rcParams.update({
    "font.size": 12,
    "font.family": "serif",
    "axes.labelsize": 14,
    "axes.titlesize": 15,
    "legend.fontsize": 11,
    "figure.dpi": 300,
    "axes.grid": True,
    "grid.alpha": 0.3,
    "grid.linestyle": "--"
})

def theoretical_mfd_curve(density, eta=0.90, c_max=100.0):
    """
    Defines the theoretical Macroscopic Fundamental Diagram (MFD).
    Free-flow increases linearly up to the critical density (eta), 
    then decays parabolically in the congested regime.
    """
    throughput = np.zeros_like(density)
    
    # Free-flow regime
    free_flow_mask = density <= (eta * c_max)
    throughput[free_flow_mask] = density[free_flow_mask]
    
    # Congested regime (Hyper-congestion)
    congested_mask = density > (eta * c_max)
    # Parabolic decay simulating intersection spillback
    decay = 1.0 - ((density[congested_mask] - (eta * c_max)) / (1.6 * c_max - (eta * c_max)))**2
    throughput[congested_mask] = (eta * c_max) * np.maximum(0.15, decay)
    
    return throughput

def simulate_mfd_trajectory(eta=0.90, c_max=100.0, controlled=True, steps=100):
    """
    Simulates network density and throughput over time.
    """
    density = np.zeros(steps)
    throughput = np.zeros(steps)
    
    current_density = 20.0 # Start empty
    
    for t in range(steps):
        # Exogenous demand surge pushing the network
        demand = 12.0 + np.random.normal(0, 1.5)
        
        if controlled:
            # The Stabilizing MARL Policy (Theorem 3.2)
            # As density approaches eta, the policy aggressively sheds demand/reroutes
            overload = max(0.0, current_density - (eta * c_max * 0.95))
            control_feedback = 0.5 * overload
            actual_arrival = max(0.0, demand - control_feedback)
        else:
            # Uncontrolled: Demand keeps pouring in
            actual_arrival = demand
            
        # Physical discharge dictated by the MFD
        ideal_discharge = theoretical_mfd_curve(np.array([current_density]), eta, c_max)[0]
        actual_discharge = min(current_density + actual_arrival, ideal_discharge)
        
        # State transition
        current_density = current_density + actual_arrival - actual_discharge
        
        density[t] = current_density
        throughput[t] = actual_discharge
        
    return density, throughput

def plot_mfd_phase_diagram():
    c_max = 100.0
    eta = 0.90
    critical_density = eta * c_max
    
    # 1. Generate the theoretical background curve
    x_theory = np.linspace(0, 160, 500)
    y_theory = theoretical_mfd_curve(x_theory, eta, c_max)
    
    # 2. Generate empirical trajectories
    np.random.seed(42)
    dens_uncontrolled, thru_uncontrolled = simulate_mfd_trajectory(eta, c_max, controlled=False, steps=150)
    dens_controlled, thru_controlled = simulate_mfd_trajectory(eta, c_max, controlled=True, steps=150)
    
    fig, ax = plt.subplots(figsize=(10, 7))
    
    # Plot the Theoretical Capacity Geometry (The MFD envelope)
    ax.plot(x_theory, y_theory, color='black', linewidth=2.5, linestyle='-', 
            label=r'Theoretical Capacity Geometry $\partial \mathcal{C}$')
    
    # Shade the Safe Interior Set
    ax.fill_between(x_theory[x_theory <= critical_density], 0, y_theory[x_theory <= critical_density], 
                    color='mediumseagreen', alpha=0.15, label=r'Strict Interior Set $\mathcal{C}^\eta$')
    
    # Shade the Hyper-Congested Regime
    ax.fill_between(x_theory[x_theory > critical_density], 0, y_theory[x_theory > critical_density], 
                    color='salmon', alpha=0.15, label=r'Unstable Regime (Hyper-Congestion)')
    
    # Plot Uncontrolled Trajectory
    ax.plot(dens_uncontrolled, thru_uncontrolled, color='darkred', linewidth=1.5, alpha=0.6, zorder=3)
    ax.scatter(dens_uncontrolled, thru_uncontrolled, c=np.arange(len(dens_uncontrolled)), 
               cmap='Reds', s=30, edgecolor='black', linewidth=0.5, zorder=4, 
               label=r'Uncontrolled Trajectory (Gridlock)')
    
    # Plot Controlled MARL Trajectory
    ax.plot(dens_controlled, thru_controlled, color='navy', linewidth=1.5, alpha=0.6, zorder=3)
    sc = ax.scatter(dens_controlled, thru_controlled, c=np.arange(len(dens_controlled)), 
               cmap='Blues', s=30, edgecolor='black', linewidth=0.5, zorder=4, 
               label=r'MARL Stabilized Trajectory ($\pi^\star$)')
    
    # Vertical line for critical density threshold
    ax.axvline(critical_density, color='gray', linestyle='--', linewidth=1.5)
    ax.text(critical_density - 3, 20, r'Critical Density Bound ($\eta c_e$)', 
            rotation=90, color='dimgray', fontsize=12, verticalalignment='bottom')

    # Formatting
    ax.set_xlabel(r'Network Load / Density ($x_e$)', labelpad=12)
    ax.set_ylabel(r'Network Throughput ($\mu_e$)', labelpad=12)
    ax.set_title(r'Empirical Macroscopic Fundamental Diagram (MFD) Phase Trajectories', pad=15)
    
    ax.set_xlim(0, 160)
    ax.set_ylim(0, 105)
    
    # Add colorbar to show time progression
    cbar = fig.colorbar(sc, ax=ax, shrink=0.6, aspect=20, pad=0.03)
    cbar.set_label('Simulation Time Step ($t$)', labelpad=10)
    cbar.set_ticks([]) # Hide numbers, just show gradient direction
    
    ax.legend(loc='upper right', framealpha=0.95)
    
    plt.tight_layout()
    plt.savefig("mfd_phase_diagram.pdf", bbox_inches="tight")
    plt.savefig("mfd_phase_diagram.png", bbox_inches="tight", dpi=300)
    plt.show()

if __name__ == "__main__":
    plot_mfd_phase_diagram()
